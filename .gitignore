# --------------------------------------------------------------------
# VPS / infra scripts — these reference operator-specific host paths,
# IPs, and config layouts that don't belong in a public repo. Keep
# them local-only; rebuild from the deploy guide if you need to.
# --------------------------------------------------------------------
musicchain/scripts/_visible-vps-*.sh
musicchain/scripts/deploy-vps.sh

# Root-level runtime/node state (never commit)
/config.json
/dht_routing_*.json
/peers.rats
/peers_ever.rats
