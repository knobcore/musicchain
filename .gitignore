# --------------------------------------------------------------------
# Root-level dirs that aren't part of the repo (vendored downloads,
# scratch trees, prebuilt toolchains). Listed explicitly so the two
# project dirs (bopwire/, bopwire_player/) include all their
# files by default — a blanket `*` ignore swallows subdirectory
# contents even with `!bopwire/` unignores.
# --------------------------------------------------------------------
/android-ndk-r27c/
/android-ndk-r27c-windows.zip
/chromaprint-1.5.1/
/chromaprint-1.5.1.tar.gz
/chromaprint-android-arm64/
/downloads/
/dist/
/kissfft-130/
/kissfft-130.tar.gz
/openssl-android/
/releases/
/*.zip
/*.tar.gz
/*.tgz

# --------------------------------------------------------------------
# bopwire core (C++): build outputs + vendored vcpkg + runtime state
# --------------------------------------------------------------------
bopwire/build/
bopwire/build-*/
bopwire/vcpkg_installed/
bopwire/.cache/
bopwire/.vs/
bopwire/.vscode/
bopwire/data/
bopwire/blocks/
bopwire/blockchain.db/
bopwire/keys/
bopwire/audio/
bopwire/*.log
bopwire/*.err
bopwire/peers.rats
bopwire/peers_ever.rats
bopwire/rats_file_transfers/
bopwire/CMakeCache.txt
bopwire/CMakeFiles/
bopwire/cmake_install.cmake
bopwire/install_manifest.txt
bopwire/compile_commands.json

# --------------------------------------------------------------------
# Vendored deps: keep librats source, drop the patched backup +
# msh3 (we're back on plain librats per the 2026-06-03 revert).
# --------------------------------------------------------------------
bopwire/deps/librats-patched-backup/
bopwire/deps/msh3/

# Build artifacts inside librats itself
bopwire/deps/librats/build/
bopwire/deps/librats/build-*/
bopwire/deps/librats/CMakeCache.txt
bopwire/deps/librats/CMakeFiles/
bopwire/deps/librats/lib/
bopwire/deps/librats/bin/

# --------------------------------------------------------------------
# Flutter player: build output, IDE state, Gradle cache, ephemeral
# --------------------------------------------------------------------
bopwire_player/build/
bopwire_player/.dart_tool/
bopwire_player/.flutter-plugins
bopwire_player/.flutter-plugins-dependencies
bopwire_player/.packages
bopwire_player/.pub-cache/
bopwire_player/.pub/
bopwire_player/.idea/
bopwire_player/.vscode/

# Android Gradle
bopwire_player/android/.gradle/
bopwire_player/android/build/
bopwire_player/android/app/build/
bopwire_player/android/.idea/
bopwire_player/android/local.properties
bopwire_player/android/key.properties

# iOS / macOS / Linux / Windows ephemeral
bopwire_player/ios/Pods/
bopwire_player/ios/Flutter/.last_build_id
bopwire_player/ios/Flutter/Generated.xcconfig
bopwire_player/ios/Flutter/flutter_export_environment.sh
bopwire_player/macos/Pods/
bopwire_player/macos/Flutter/ephemeral/
bopwire_player/linux/flutter/ephemeral/
bopwire_player/windows/flutter/ephemeral/

# Local runtime data
bopwire_player/rats_file_transfers/
bopwire_player/dht_routing_*.json
bopwire_player/dht_routing.json
bopwire_player/offline_play_log.db
bopwire_player/peers.rats
bopwire_player/peers_ever.rats
bopwire_player/config.json
bopwire_player/*.zip
bopwire_player/*.apk

# Editor / OS scratch
bopwire_player/*.lock

# --------------------------------------------------------------------
# Common cross-cutting binary outputs
# --------------------------------------------------------------------
**/*.o
**/*.obj
**/*.exe
**/*.dll
**/*.so
**/*.so.*
**/*.dylib
**/*.lib
**/*.a
**/*.pdb
**/*.exp
**/*.ilk
**/*.apk
**/*.aab
**/*.aar
**/*.jar
**/*.class

# DS_Store / Thumbs
**/.DS_Store
**/Thumbs.db
vcpkg-linux/
bopwire_player/apk-build2.tail
bopwire_player/apk-build.log
bopwire_player/android/.kotlin/

# --------------------------------------------------------------------
# VPS / infra scripts — these reference operator-specific host paths,
# IPs, and config layouts that don't belong in a public repo. Keep
# them local-only; rebuild from the deploy guide if you need to.
# --------------------------------------------------------------------
bopwire/scripts/_visible-vps-*.sh
bopwire/scripts/deploy-vps.sh

# Root-level runtime/node state (never commit)
/config.json
/dht_routing_*.json
/peers.rats
/peers_ever.rats
